{
  "name": "@neuro/sdk",
  "version": "0.1.0",
  "description": "Developer SDK and A2A runtime for Neuro agents",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@neuro/core": "*",
    "hono": "^4.4.7",
    "zod": "^3.23.8",
    "@hono/node-server": "^1.11.2",
    "yaml": "^2.4.5",
    "ai": "latest",
    "@ai-sdk/openai": "latest",
    "@ai-sdk/anthropic": "latest",
    "@modelcontextprotocol/sdk": "latest"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
