# Copy this file to .env.release and fill in your values
# NEVER commit .env.release

# Optional: push to GitHub before npm publish (omit both to skip)
# GITHUB_TOKEN needs repo scope — https://github.com/settings/tokens/new
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_REPO=your-username/neuro

# npm access token (Automation type, needs publish scope)
# Create at: https://www.npmjs.com/settings/tokens/new
NPM_TOKEN=npm_your_token_here
