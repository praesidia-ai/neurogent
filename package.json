{
  "name": "neuro-monorepo",
  "private": true,
  "packageManager": "npm@10.8.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,yaml,json}\""
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.0",
    "prettier": "^3.3.0",
    "eslint": "^9.5.0",
    "@types/node": "latest"
  },
  "workspaces": [
    "packages/ts/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
